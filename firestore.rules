rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permite que qualquer usuário autenticado leia e escreva em seu próprio documento na coleção 'users'
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Permite que usuários autenticados gerenciem suas próprias chaves PIX
    match /pix_keys/{keyId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }
    
    // Regra fallback - negar tudo por padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
